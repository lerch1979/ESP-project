# Leave VITE_API_URL UNSET for normal dev — resolveApiBase() in
# services/api.js falls back to the relative /api/v1 path, which Vite
# proxies to the backend on the same origin. That keeps things working
# whether you load the page from localhost / 127.0.0.1 / LAN IP / ngrok.
# Set this only when pointing the admin UI at a remote backend with its
# own domain (e.g. staging or a paid ngrok with a separate backend host).
# VITE_API_URL=https://api.staging.hr-erp.example.com/api/v1

# ─── Error reporting (Sentry) ──────────────
# Unset = disabled. Paste your Sentry DSN to turn on.
# VITE_SENTRY_DSN=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# VITE_SENTRY_RELEASE=

# HR-ERP production env — TEMPLATE (no real secrets here).
# On rebuild: copy to `.env.production`, paste the real values from Bitwarden
# (vault item "HR-ERP prod .env"), then symlink `.env -> .env.production`
# (compose interpolates ${DB_PASSWORD} from the default `.env`).

NODE_ENV=production
PORT=3001
API_VERSION=v1

# ── Database (internal postgres container) ──
DB_HOST=postgres
DB_PORT=5432
DB_NAME=hr_erp
DB_USER=postgres
DB_PASSWORD=__PASTE_FROM_BITWARDEN__
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

REDIS_HOST=redis
REDIS_PORT=6379

# ── Auth ──
JWT_SECRET=__PASTE_FROM_BITWARDEN__
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d

# ── Web / security (set CORS/FRONTEND to the new domain if it changes) ──
CORS_ORIGIN=https://app.housingsolutions.hu
FRONTEND_URL=https://app.housingsolutions.hu
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
CSRF_ENABLED=true
SECURITY_HEADERS_ENABLED=true
MAX_FILE_SIZE=10485760
UPLOAD_DIR=/app/uploads
LOG_LEVEL=info

# ── Claude AI ──
ANTHROPIC_API_KEY=__PASTE_FROM_BITWARDEN__

# ── PII encryption — MUST be the exact original value or restored PII won't decrypt ──
ENCRYPTION_KEY=__PASTE_FROM_BITWARDEN__

# ── Error monitoring (optional) ──
SENTRY_DSN=__PASTE_FROM_BITWARDEN_OR_LEAVE_BLANK__
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Integrations off for the pilot ──
EMAIL_ASSISTANT_ENABLED=false
EMAIL_ASSISTANT_ENABLE_ACTIONS=false
EMAIL_ASSISTANT_REPLY=false
TICKET_CHAT_EMAIL_OUTBOUND=false

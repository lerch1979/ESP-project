{
  "name": "hr-erp-backend",
  "version": "1.0.0",
  "description": "HR-ERP Rendszer Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "db:migrate": "node src/database/migrate.js run",
    "db:migrate:status": "node src/database/migrate.js status",
    "db:migrate:rollback": "node src/database/migrate.js rollback",
    "db:migrate:seed": "node src/database/migrate.js seed",
    "db:migrate:baseline": "node src/database/migrate.js baseline",
    "db:seed": "node src/database/seed.js",
    "agent:ceo": "node scripts/ceo_agent.js",
    "agent:standup": "node scripts/daily_standup.js",
    "agent:qa": "node scripts/qa_agent.js",
    "backup:now": "node scripts/auto_backup.js",
    "backup:dry": "node scripts/auto_backup.js --dry-run",
    "security:encrypt-pii": "node migrations/run_encrypt_pii.js",
    "security:encrypt-pii:dry": "node migrations/run_encrypt_pii.js --dry-run",
    "security:generate-key": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "test:security": "jest tests/security/ tests/encryption.test.js tests/rateLimiter.test.js tests/csrf.test.js tests/securityHeaders.test.js --verbose",
    "test:security:watch": "jest tests/security/ tests/encryption.test.js tests/rateLimiter.test.js tests/csrf.test.js tests/securityHeaders.test.js --watch",
    "report:daily": "node scripts/daily_report.js",
    "report:daily:dry": "node scripts/daily_report.js --dry-run",
    "report:daily:pdf": "node scripts/daily_report.js --dry-run --pdf-only",
    "report:daily:excel": "node scripts/daily_report.js --dry-run --excel-only",
    "security:scan-sql": "node scripts/scan_sql_injection.js",
    "security:audit-validation": "node scripts/audit_validation.js"
  },
  "keywords": [
    "hr",
    "erp",
    "ticketing",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-slow-down": "^3.1.0",
    "express-validator": "^7.0.1",
    "googleapis": "^171.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.7",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sharp": "^0.34.5",
    "socket.io": "^4.6.1",
    "tesseract.js": "^7.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}

# ─── Production Environment ──────────────────
# Copy to .env and fill in values

NODE_ENV=production
PORT=3000
API_VERSION=v1

# ─── Database ────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=hr_erp_db
DB_USER=hr_erp_app
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_SSL=true
DB_POOL_MAX=100
DB_POOL_MIN=10

# ─── JWT (8h access, 30d refresh) ───────────
JWT_SECRET=CHANGE_THIS_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS ────────────────────────────────────
CORS_ORIGIN=https://app.yourdomain.com,https://admin.yourdomain.com

# ─── CSRF ────────────────────────────────────
CSRF_ENABLED=true

# ─── Rate Limiting ───────────────────────────
# Defaults: 100 req/min global, 10 req/min auth
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ─── Redis (optional, for session/cache) ─────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── AI/NLP (optional) ──────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Slack (optional) ───────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...

# ─── Email ──────────────────────────────────
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=
# EMAIL_PASSWORD=

# ─── Cluster ────────────────────────────────
# CLUSTER_WORKERS=4  (defaults to CPU count)

# ─── CarePath Encryption ────────────────────
# CAREPATH_ENCRYPTION_KEY=CHANGE_THIS

# ─── Server ──────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ─── Database (PostgreSQL) ───────────────────
# Docker: DB_HOST=postgres | Local: DB_HOST=localhost
DB_HOST=postgres
DB_PORT=5432
DB_NAME=hr_erp_db
DB_USER=postgres
DB_PASSWORD=postgres

# ─── Database SSL ──────────────────────────
# Set DB_SSL=true to enable SSL/TLS connection (recommended for production)
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_CA=/path/to/ca-certificate.crt

# ─── Redis ───────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── JWT ─────────────────────────────────────
JWT_SECRET=GENERATE-WITH-node-e-require-crypto-randomBytes-64-toString-hex
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS ────────────────────────────────────
CORS_ORIGIN=http://localhost:3001,http://localhost:19006

# ─── Rate Limiting ───────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── CSRF Protection ───────────────────────
CSRF_ENABLED=true

# ─── Security Headers ──────────────────────
SECURITY_HEADERS_ENABLED=true
# CSP_REPORT_URI=/api/v1/csp-report

# ─── File Upload ─────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# ─── Email ───────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# ─── Claude API (Invoice OCR + Chatbot AI) ───
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=1024

# ─── Gmail Integration ──────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=
GMAIL_REFRESH_TOKEN=

# ─── Google Calendar ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
FRONTEND_URL=http://localhost:3001

# ─── Agent Configuration ────────────────────
AGENT_EMAIL_TO=
GITHUB_TOKEN=
GITHUB_REPO=

# ─── PII Encryption ─────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=<generate-32-byte-random-key>

# ─── Logging ────────────────────────────────
LOG_LEVEL=info

# ─── Error reporting (Sentry) ──────────────
# Unset = disabled (local dev, CI). In prod, paste your Sentry project DSN.
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_RELEASE=
